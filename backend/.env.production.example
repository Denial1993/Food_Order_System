APP_ENV=production
DEBUG=false

# Supabase connection string（Connect → Session pooler Port 5432）
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-x-ap-south-1.pooler.supabase.com:5432/postgres

# 產生方式：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=YOUR_STRONG_RANDOM_SECRET

# Render Static Site 部署後的前端 URL
CORS_ORIGINS_STR=https://your-app.onrender.com,http://localhost:5173

# Supabase → Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Supabase → Settings → API → service_role（eyJhbGci... 開頭）
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=menu-images
