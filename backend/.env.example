APP_NAME=Food Order System
APP_ENV=dev
DEBUG=true

# ── 資料庫（二選一）─────────────────────────────────────────────
# 方法 A：直接填完整 URL（Supabase / Render 部署用）
# Supabase 格式：postgresql://postgres:[密碼]@db.[ref].supabase.co:5432/postgres
# DATABASE_URL=postgresql://postgres:yourpassword@db.xxxx.supabase.co:5432/postgres

# 方法 B：分項設定（本機 Docker 開發用，DATABASE_URL 未設時生效）
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=food_order_db

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── CORS（逗號分隔，取代舊的 JSON 陣列格式）────────────────────
# 本機開發
CORS_ORIGINS_STR=http://localhost:5173,http://127.0.0.1:5173
# 正式環境範例（Render Static Site URL + 本機）
# CORS_ORIGINS_STR=https://food-order.onrender.com,http://localhost:5173

# ── Supabase Storage（圖片上傳，選填）───────────────────────────
# Supabase Dashboard → Settings → API
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOi...   (service_role key，不是 anon key)
# SUPABASE_STORAGE_BUCKET=menu-images
